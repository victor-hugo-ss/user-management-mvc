<div class="page-header">
  <div>
    <h1>Usuários</h1>
    <p>{{users.length}} usuário(s) cadastrado(s).</p>
  </div>
</div>

{{#if users.length}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Nome</th>
          <th>Ocupação</th>
          <th>Idade</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each users}}
          <tr>
            <td>
              <div class="user-name">{{this.name}} {{this.lastname}}</div>
            </td>
            <td><span class="badge">{{this.occupation}}</span></td>
            <td>{{this.age}} anos</td>
            <td class="actions">
              <a
                href="/user/{{this.id}}"
                class="action-btn"
                title="Ver detalhes"
              >
                <svg viewBox="0 0 24 24"><path
                    d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"
                  /><circle cx="12" cy="12" r="3" /></svg>
              </a>
              <a
                href="/users/edit/{{this._id}}"
                class="action-btn"
                title="Editar"
              >
                <svg viewBox="0 0 24 24"><path
                    d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
                  /><path
                    d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
                  /></svg>
              </a>
              <form
                action="/users/delete/{{this._id}}?_method=DELETE"
                method="POST"
                onsubmit="return confirm('Excluir {{this.name}}?')"
              >
                <button type="submit" class="action-btn danger" title="Excluir">
                  <svg viewBox="0 0 24 24"><polyline
                      points="3 6 5 6 21 6"
                    /><path
                      d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"
                    /><path d="M10 11v6M14 11v6" /><path
                      d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"
                    /></svg>
                </button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <div class="empty">
    <svg viewBox="0 0 24 24"><path
        d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
      /><circle cx="9" cy="7" r="4" /><path
        d="M23 21v-2a4 4 0 0 0-3-3.87"
      /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
    <p>Nenhum usuário cadastrado ainda.</p>
    <a href="add" class="btn-primary">+ novo usuário</a>
  </div>
{{/if}}